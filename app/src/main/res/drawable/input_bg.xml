<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <solid android:color="@android:color/white"/>

    <!-- Rounded corners -->
    <corners android:radius="8dp"/>

    <!-- Black border -->
    <stroke
        android:width="1dp"
        android:color="#000000"/>

    <!-- Inner spacing -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="10dp"
        android:bottom="10dp"/>
</shape>